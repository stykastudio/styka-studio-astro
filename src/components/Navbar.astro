---
import Container from "../components/Container.astro";
import Link from "../components/ui/Link.astro";
import { Image } from "astro:assets";
import Logo from "../../src/assets/styka_logo_web.svg";
import { Phone } from "lucide-astro";
import Button from "./ui/Button.astro";
---

<!-- component -->
<Container>
	<nav class="bg-tan-900 w-100 px-2 md:px-auto">
		<div
			class="md:h-16 h-28 mx-auto md:px-4 container flex items-center justify-between flex-wrap md:flex-nowrap"
		>
			<!-- Logo -->
			<a href="/">
				<div class="text-indigo-500 md:order-1">
					<!-- Heroicon - Chip Outline -->
					<Image src={Logo} alt="Styka Studio" width={130} />
				</div>
			</a>
			<div class="text-gray-500 order-3 w-full md:w-auto md:order-2">
				<ul class="flex justify-between text-jet-400">
					<!-- Active Link = text-indigo-500
                Inactive Link = hover:text-indigo-500 -->
					<li class="md:px-4 md:py-2">
						<a href="/">Home</a>
					</li>
					<li class="md:px-4 md:py-2 hover:text-jet-600">
						<a href="/portfolio">Portfolio</a>
					</li>
					<li class="md:px-4 md:py-2 hover:text-jet-600">
						<a href="#">Services</a>
					</li>
					<li class="md:px-4 md:py-2 hover:text-jet-600">
						<a href="#">About</a>
					</li>
					<li class="md:px-4 md:py-2 hover:text-jet-600">
						<a href="#">Contact</a>
					</li>
				</ul>
			</div>
			<div class="order-2 md:order-3">
				<!-- Heroicons - Login Solid -->
				<Button
					size="md"
					style="primary"
					class="flex gap-1 items-center justify-center"
				>
					<Phone size={16} /><div class="text-sm">7799620614</div>
				</Button>
			</div>
		</div>
	</nav>
</Container>
