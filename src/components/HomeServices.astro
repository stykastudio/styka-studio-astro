---
import { DraftingCompass, PencilRuler, Home, Drill } from "lucide-astro";
---

<div class="z-0 hero-bg-curtain-tan">
	<div class="bg-gradient-to-b from-tan-900 via-tan-800 to-transparent">
		<div class="max-w-screen-xl px-4 py-10 sm:px-6 lg:px-8 lg:py-14 mx-auto">
			<div class="max-w-2xl mx-auto">
				<div class="grid gap-12">
					<div>
						<h2
							class="font-semibold text-gray-900 text-3xl md:text-4xl lg:text-5xl text-center"
						>
							Our Services
						</h2>
						{
							/* <p class="mt-3 text-gray-800 ">
							For as long as there have been cities, the public square has been
							a fundamental part of the urban landscape - an open, approachable
							space to meet and engage with friends and neighbours. Space aims
							to capture this spirit of bringing people together in an exciting,
							welcoming environment.
						</p> */
						}
					</div>

					<div class="space-y-6 lg:space-y-10">
						<div class="flex">
							<DraftingCompass
								class="flex-shrink-0 mt-2 size-6 text-gray-800"
							/>

							<div class="ms-5 sm:ms-8">
								<h3 class="text-base sm:text-lg font-semibold text-gray-800">
									Architectural Planning & Design
								</h3>
								<p class="mt-1 text-gray-600">
									From designer houses to commercial buildings, our experienced
									architects offer optimized and functional space planning for a
									variety of projects.
								</p>
							</div>
						</div>

						<div class="flex">
							<PencilRuler class="flex-shrink-0 mt-2 size-6 text-gray-800" />
							<div class="ms-5 sm:ms-8">
								<h3 class="text-base sm:text-lg font-semibold text-gray-800">
									Architectural Modeling & Rendering
								</h3>
								<p class="mt-1 text-gray-600">
									We specialize in creating awe-inspiring elevation designs that
									seamlessly blend creativity with practicality, ensuring your
									building stands out from the rest.
								</p>
							</div>
						</div>

						<div class="flex">
							<Home class="flex-shrink-0 mt-2 size-6 text-gray-800" />
							<div class="ms-5 sm:ms-8">
								<h3 class="text-base sm:text-lg font-semibold text-gray-800">
									Interior Design
								</h3>
								<p class="mt-1 text-gray-600">
									Our interior design services encompass a comprehensive
									process, translating client needs into practical, creative
									designs. From conceptualization to execution, we ensure
									precision and finesse in every detail.
								</p>
							</div>
						</div>
						<div class="flex">
							<Drill class="flex-shrink-0 mt-2 size-6 text-gray-800 e" />
							<div class="ms-5 sm:ms-8">
								<h3 class="text-base sm:text-lg font-semibold text-gray-800">
									Interiors Execution
								</h3>
								<p class="mt-1 text-gray-600">
									We ensure timely and precise execution of interior design
									projects, utilizing our expertise, resources, and processes to
									bring your vision to life.
								</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>
